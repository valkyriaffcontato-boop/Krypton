<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Krypton Bot | Central de Suporte</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    .gradient-bg {
      background: radial-gradient(circle at 50% -20%, #1e1b4b 0%, #0f172a 70%);
    }
  </style>
</head>
<body class="gradient-bg text-slate-100 min-h-screen flex flex-col justify-between font-sans antialiased">

  <!-- Navbar -->
  <header class="w-full max-w-7xl mx-auto px-6 py-5 flex justify-between items-center">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-tr from-violet-600 to-indigo-600 flex items-center justify-center font-black text-xl shadow-lg shadow-violet-500/20">K</div>
      <span class="text-xl font-bold tracking-tight">Krypton</span>
    </div>
    <div>
      <% if (user) { %>
        <a href="/dashboard" class="bg-slate-800 hover:bg-slate-700 text-white font-medium py-2.5 px-5 rounded-xl border border-slate-700/80 transition-all text-sm shadow-md">Ir para o Painel</a>
      <% } else { %>
        <a href="/auth/login" class="bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 px-5 rounded-xl transition-all text-sm shadow-lg shadow-violet-600/30">Acessar Painel</a>
      <% } %>
    </div>
  </header>

  <!-- Hero Section -->
  <main class="flex-grow flex items-center justify-center px-6 py-12 md:py-24">
    <div class="max-w-4xl mx-auto text-center space-y-8">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-violet-500/10 border border-violet-500/20 text-xs font-semibold text-violet-400">
        ✨ Sistema de Tickets Inteligente e Avançado
      </div>
      
      <h1 class="text-4xl md:text-6xl font-black tracking-tight leading-tight md:leading-none">
        Gerencie o suporte do seu <br class="hidden md:inline">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-violet-400 via-indigo-400 to-purple-500">servidor de forma profissional</span>
      </h1>
      
      <p class="text-base md:text-lg text-slate-400 max-w-2xl mx-auto leading-relaxed">
        O Krypton oferece um sistema de tickets robusto, logs automatizados de auditoria, históricos de chats em HTML e um painel de controle web projetado para facilitar o atendimento da sua equipe.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <!-- Link de Convite Oficial do Bot -->
        <a href="https://discord.com/oauth2/authorize?client_id=<%= clientId %>&permissions=8&scope=bot%20applications.commands" 
           target="_blank" 
           class="w-full sm:w-auto bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white font-semibold py-4 px-8 rounded-xl shadow-md transition-all flex items-center justify-center gap-3">
          <svg class="w-5 h-5 text-indigo-400" viewBox="0 0 127.14 96.36" fill="currentColor">
            <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a77.7,77.7,0,0,0,6.63-10.85,68.43,68.43,0,0,1-10.45-5c.87-.64,1.71-1.32,2.51-2a75.4,75.4,0,0,0,72.84,0c.8.7,1.64,1.38,2.51,2a68.43,68.43,0,0,1-10.45,5,77.7,77.7,0,0,0,6.63,10.85,105.73,105.73,0,0,0,31-18.83C129.1,50.15,123.11,27.32,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.83,46,53.83,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,84.69,40.36,96.07,46,96.07,53,91,65.69,84.69,65.69Z"/>
          </svg>
          Adicionar ao Servidor
        </a>
        
        <% if (user) { %>
          <a href="/dashboard" class="w-full sm:w-auto bg-violet-600 hover:bg-violet-500 text-white font-semibold py-4 px-8 rounded-xl shadow-lg shadow-violet-600/20 transition-all text-center">
            Acessar Meu Painel
          </a>
        <% } else { %>
          <a href="/auth/login" class="w-full sm:w-auto bg-violet-600 hover:bg-violet-500 text-white font-semibold py-4 px-8 rounded-xl shadow-lg shadow-violet-600/20 transition-all text-center">
            Entrar com o Discord
          </a>
        <% } %>
      </div>
    </div>
  </main>

  <!-- Rodapé -->
  <footer class="w-full max-w-7xl mx-auto px-6 py-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-slate-500">
    <p>&copy; 2026 Krypton Bot. Todos os direitos reservados.</p>
    <div class="flex gap-6">
      <a href="#" class="hover:text-slate-300">Termos de Uso</a>
      <a href="#" class="hover:text-slate-300">Privacidade</a>
    </div>
  </footer>

</body>
</html>
