<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Krypton | Meus Servidores</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#0f172a] text-slate-100 min-h-screen font-sans">

  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Header -->
    <header class="flex flex-col sm:flex-row justify-between items-center gap-4 mb-10 pb-6 border-b border-slate-800">
      <div class="flex items-center gap-4">
        <% if (user.avatar) { %>
          <img src="https://cdn.discordapp.com/avatars/<%= user.id %>/<%= user.avatar %>.png" class="w-12 h-12 rounded-full border border-violet-500/30" />
        <% } else { %>
          <div class="w-12 h-12 rounded-full bg-slate-800 flex items-center justify-center font-bold">U</div>
        <% } %>
        <div>
          <div class="flex items-center gap-2">
            <h1 class="text-2xl font-bold tracking-tight">Olá, <%= user.username %></h1>
            <% if (role === 'superadmin') { %>
              <span class="bg-violet-500/10 text-violet-400 border border-violet-500/30 text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full">Developer Master</span>
            <% } %>
          </div>
          <p class="text-xs text-slate-400">Escolha um servidor para gerenciar as configurações</p>
        </div>
      </div>
      <div class="flex gap-3">
        <a href="/" class="bg-slate-800 hover:bg-slate-700 text-sm font-medium py-2 px-4 rounded-xl transition-all">Página Inicial</a>
        <a href="/auth/logout" class="bg-red-500/10 hover:bg-red-500/20 text-red-400 text-sm font-medium py-2 px-4 rounded-xl border border-red-500/20 transition-all">Desconectar</a>
      </div>
    </header>

    <!-- ABA EXCLUSIVA DE DESENVOLVEDOR (mafiosodashopping@gmail.com) -->
    <% if (role === 'superadmin') { %>
      <section class="bg-slate-900/40 border border-violet-500/20 p-6 rounded-2xl mb-10 shadow-xl space-y-6">
        <h2 class="text-lg font-bold text-violet-400 flex items-center gap-2">🕹️ Central de Controle Global do Bot (Developer Master)</h2>
        <p class="text-xs text-slate-400">Esta seção é exibida apenas para o e-mail de acesso pleno. Qualquer alteração aqui reflete instantaneamente nas atividades do bot no Discord.</p>
        
        <form action="/developer/presence" method="POST" class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Mensagem de Atividade do Bot</label>
            <input type="text" name="activityName" placeholder="Ex: canais de suporte" class="w-full bg-slate-950 p-3 rounded-xl border border-slate-800 focus:border-violet-500 text-sm text-slate-200 outline-none" required />
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Tipo de Atividade</label>
            <select name="activityType" class="w-full bg-slate-950 p-3 rounded-xl border border-slate-800 focus:border-violet-500 text-sm text-slate-200 outline-none">
              <option value="0">Jogando (Playing)</option>
              <option value="2">Ouvindo (Listening)</option>
              <option value="3" selected>Assistindo (Watching)</option>
              <option value="5">Competindo (Competing)</option>
            </select>
          </div>

          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Status do Bot</label>
            <select name="status" class="w-full bg-slate-950 p-3 rounded-xl border border-slate-800 focus:border-violet-500 text-sm text-slate-200 outline-none">
              <option value="online">Online</option>
              <option value="idle">Ausente (Idle)</option>
              <option value="dnd">Não Perturbar (DND)</option>
              <option value="invisible">Invisível</option>
            </select>
          </div>

          <div class="md:col-span-3">
            <button type="submit" class="w-full bg-violet-600 hover:bg-violet-500 text-white font-bold py-3.5 rounded-xl transition text-sm shadow-lg shadow-violet-600/20">
              Atualizar Presença e Atividade Global do Bot
            </button>
          </div>
        </form>
      </section>
    <% } %>

    <!-- Lista de Servidores -->
    <main>
      <h2 class="text-lg font-bold text-slate-400 uppercase tracking-wider mb-6">Seus Servidores com Administração</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% guilds.forEach(g => { %>
          <div class="bg-slate-900/60 p-6 rounded-2xl flex flex-col justify-between border border-slate-800/80 shadow-lg hover:border-violet-500/40 hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex items-center gap-4 mb-6">
              <% if (g.icon) { %>
                <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" class="w-16 h-16 rounded-2xl" />
              <% } else { %>
                <div class="w-16 h-16 rounded-2xl bg-slate-800 flex items-center justify-center font-extrabold text-xl text-violet-400"><%= g.name[0] %></div>
              <% } %>
              <div class="overflow-hidden">
                <h3 class="font-bold text-lg truncate text-slate-100"><%= g.name %></h3>
                <p class="text-xs text-slate-500 truncate">ID: <%= g.id %></p>
              </div>
            </div>
            
            <a href="/dashboard/<%= g.id %>" class="w-full text-center bg-violet-600 hover:bg-violet-500 text-white font-semibold py-2.5 px-4 rounded-xl transition-all text-sm shadow-md shadow-violet-600/10">
              Configurar Painel
            </a>
          </div>
        <% }) %>
      </div>
    </main>
  </div>

</body>
</html>
