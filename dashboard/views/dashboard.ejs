<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Krypton | Meus Servidores</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-white p-8">
  <div class="max-w-4xl mx-auto">
    <header class="flex justify-between items-center mb-10 pb-4 border-b border-slate-700">
      <h1 class="text-3xl font-bold">Olá, <%= user.username %>!</h1>
      <a href="/auth/logout" class="text-red-400 hover:underline">Sair</a>
    </header>
    <h2 class="text-xl font-semibold mb-6">Selecione um Servidor para Configurar:</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% guilds.forEach(g => { %>
        <div class="bg-slate-800 p-6 rounded-xl flex items-center justify-between border border-slate-700 shadow-md">
          <div class="flex items-center gap-4">
            <% if (g.icon) { %>
              <img src="https://cdn.discordapp.com/icons/<%= g.id %>/<%= g.icon %>.png" class="w-14 h-14 rounded-full" />
            <% } else { %>
              <div class="w-14 h-14 rounded-full bg-slate-700 flex items-center justify-center font-bold text-lg"><%= g.name[0] %></div>
            <% } %>
            <div>
              <h3 class="font-bold text-lg"><%= g.name %></h3>
              <p class="text-xs text-slate-400">ID: <%= g.id %></p>
            </div>
          </div>
          <a href="/dashboard/<%= g.id %>" class="bg-violet-600 hover:bg-violet-700 px-4 py-2 rounded font-semibold text-sm transition">Gerenciar</a>
        </div>
      <% }) %>
    </div>
  </div>
</body>
</html>
